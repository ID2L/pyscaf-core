FROM python:3.12-slim

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

COPY {{ service.dir }}/pyproject.toml {{ service.dir }}/uv.lock* ./
RUN uv sync --frozen --no-install-project

COPY {{ service.dir }}/ .

CMD ["uv", "run", "uvicorn", "{{ project_name | replace("-", "_") }}.main:app", "--host", "0.0.0.0", "--port", "{{ service.port }}", "--reload"]
