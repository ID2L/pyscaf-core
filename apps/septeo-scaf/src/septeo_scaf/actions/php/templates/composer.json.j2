{
    "name": "septeo/{{ project_name }}",
    "description": "",
    "type": "project",
    "require": {
        "php": ">=8.3"
{%- if framework == "symfony" %},
        "symfony/framework-bundle": "^7.2",
        "symfony/runtime": "^7.2"
{%- if "api-platform" in addons %},
        "api-platform/core": "^4.0"
{%- endif %}
{%- elif framework == "laravel" %},
        "laravel/framework": "^12.0"
{%- endif %}

    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.68",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    }
}
