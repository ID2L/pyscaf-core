{
  "name": "{{ project_name }}-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
{%- if frontend_tech == "react" %}
    "react": "^19.0",
    "react-dom": "^19.0"
{%- elif frontend_tech == "vue" %}
    "vue": "^3.5"
{%- elif frontend_tech == "svelte" %}
    "svelte": "^5.0"
{%- endif %}
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vite": "^6.2",
{%- if frontend_tech == "react" %}
    "@vitejs/plugin-react": "^4.3",
    "@types/react": "^19.0",
    "@types/react-dom": "^19.0",
{%- elif frontend_tech == "vue" %}
    "@vitejs/plugin-vue": "^5.2",
{%- elif frontend_tech == "svelte" %}
    "@sveltejs/vite-plugin-svelte": "^5.0",
{%- endif %}
    "vitest": "^3.0",
    "eslint": "^9.0",
    "@eslint/js": "^9.0",
    "prettier": "^3.5"
  }
}
