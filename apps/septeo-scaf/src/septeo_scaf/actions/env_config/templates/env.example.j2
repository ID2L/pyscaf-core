# {{ project_name }} — Environment Configuration
# Copy this file to .env and fill in your values.

# Application
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
{%- if database and database != "none" %}

# Database
{%- if "postgres" in database %}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/{{ project_name | replace("-", "_") }}
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB={{ project_name | replace("-", "_") }}
{%- elif "mysql" in database %}
DATABASE_URL=mysql://root:root@localhost:3306/{{ project_name | replace("-", "_") }}
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE={{ project_name | replace("-", "_") }}
{%- endif %}
{%- endif %}
{%- if serverless %}

# LocalStack (Serverless)
LOCALSTACK_AUTH_TOKEN=your-auth-token-here
AWS_DEFAULT_REGION=eu-west-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
{%- endif %}
{%- if has_python %}

# Python
PYTHONPATH=src
{%- endif %}
{%- if has_javascript %}

# Node
NODE_ENV=development
{%- endif %}
